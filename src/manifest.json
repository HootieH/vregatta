{
  "manifest_version": 3,
  "name": "vRegatta",
  "version": "0.3.3",
  "description": "Virtual Regatta sailing tools — data capture & analytics",
  "permissions": ["storage", "scripting", "activeTab", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://play.offshore.virtualregatta.com/*",
        "*://play.inshore.virtualregatta.com/*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/icon128.svg"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "*://play.offshore.virtualregatta.com/*",
        "*://play.inshore.virtualregatta.com/*"
      ]
    },
    {
      "resources": ["dashboard/dashboard.html", "dashboard/dashboard.js", "dashboard/dashboard.css", "dashboard/leaflet.css"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["dashboard/inshore-dashboard.html", "dashboard/inshore-dashboard.js", "dashboard/inshore-dashboard.css"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["rules/rule-page.html", "rules/rule-page.css", "rules/rule-page.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "128": "icons/icon128.svg"
  }
}
